# Security Headers
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "DENY" 
Header always set Content-Security-Policy "default-src 'self'; img-src 'self' https://uptime.betterstack.com; script-src 'none'; style-src 'self' 'unsafe-inline'; frame-ancestors 'none'; base-uri 'self'; form-action 'none';"
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"

# SVG Special Case - Allow this file to be loaded from anywhere
<Files "logo.svg">
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET"
    Header set X-Frame-Options "SAMEORIGIN"
</Files>

# Disable directory browsing
Options -Indexes

# Block access to sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect against common vulnerabilities
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Block access to potentially dangerous files
    RewriteRule ^(.*/)?\.git/ - [F,L]
    
    # HTTPS redirect
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Disable server signature
ServerSignature Off